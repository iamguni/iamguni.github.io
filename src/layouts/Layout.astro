---
interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content="Personal Portfolio of Gurmeet Singh - A Coding Kavi showing technical and poetry expertise." />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/png" href="/Normal Logo - Transparent.PNG" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Playfair+Display:ital,wght@0,400;0,700;1,400&display=swap" rel="stylesheet">
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
  </head>
  <body class="bg-brand-dark text-gray-100 font-sans antialiased min-h-screen flex flex-col justify-between">
    <slot />
  </body>
</html>

<style is:global>
  /* Custom global scrollbars and selection colors */
  ::-webkit-scrollbar {
    width: 8px;
  }
  ::-webkit-scrollbar-track {
    background: #121212;
  }
  ::-webkit-scrollbar-thumb {
    background: #FFD200;
    border-radius: 4px;
  }
  ::selection {
    background-color: #FFD200;
    color: #121212;
  }
</style>
